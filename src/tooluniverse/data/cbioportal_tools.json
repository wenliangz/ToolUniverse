      "return_format": "JSON"
    },
    "return_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "genePanelId": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "test_examples": [{"page_size": 10}]
  },
  {
    "type": "CBioPortalRESTTool",
    "name": "cBioPortal_get_gene_panel_genes",
    "description": "Get all genes in a specific gene panel. Essential for understanding what genes are covered when analyzing mutation frequency data from targeted sequencing studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_panel_id": {"type": "string", "description": "Gene panel ID (e.g., 'IMPACT468')"}
      },
      "required": ["gene_panel_id"]
    },
    "fields": {
      "endpoint": "https://www.cbioportal.org/api/gene-panels/{gene_panel_id}",
      "return_format": "JSON"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "genePanelId": {"type": "string"},
        "description": {"type": "string"},
        "genes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entrezGeneId": {"type": "integer"},
              "hugoGeneSymbol": {"type": "string"}
            }
          }
        }
      }
    },
    "test_examples": [{"gene_panel_id": "IMPACT468"}, {"gene_panel_id": "IMPACT341"}]
  },
  {
