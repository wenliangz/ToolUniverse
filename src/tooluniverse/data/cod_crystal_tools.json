              },
              "calcformula": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "commonname": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Common compound name"
              },
              "mineral": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Mineral name"
              },
              "chemname": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "sg": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Space group symbol"
              },
              "sgNumber": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Space group number (1-230)"
              },
              "a": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell parameter a (Angstroms)"
              },
              "b": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell parameter b (Angstroms)"
              },
              "c": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell parameter c (Angstroms)"
              },
              "alpha": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell angle alpha (degrees)"
              },
              "beta": {
                "type": [
                  "string",
