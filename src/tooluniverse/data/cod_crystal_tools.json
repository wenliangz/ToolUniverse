                ],
                "description": "Unit cell angle beta (degrees)"
              },
              "gamma": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell angle gamma (degrees)"
              },
              "vol": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unit cell volume (Angstroms^3)"
              },
              "doi": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Publication DOI"
              },
              "journal": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "year": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "authors": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "method": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Diffraction method"
              },
              "radiation": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
