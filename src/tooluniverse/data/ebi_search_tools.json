  },
  {
    "type": "EBISearchRESTTool",
    "name": "ebi_get_domain_fields",
    "description": "Get list of available searchable fields for a specific EBI domain. Useful for understanding what fields can be used in queries and field-specific searches.",
    "parameter": {
      "type": "object",
      "properties": {
        "domain": {
          "type": "string",
          "description": "EBI domain name"
        },
        "format": {
          "type": "string",
          "enum": ["json", "xml"],
          "default": "json"
        }
      },
      "required": ["domain"]
    },
    "fields": {
      "endpoint": "",
      "extract_path": "fields",
      "return_format": "JSON"
    },
    "return_schema": {
      "type": "array",
      "description": "List of available fields with metadata",
      "items": {
        "type": "object"
      }
    },
    "test_examples": [
      {
        "domain": "ensembl"
      },
      {
        "domain": "uniprot"
      }
    ]
  },
  {
    "type": "EBISearchRESTTool",
    "name": "ebi_cross_reference_search",
    "description": "Search for cross-references between EBI domains. Find entries in one domain that reference entries in another domain (e.g., find UniProt entries referenced by Ensembl genes).",
    "parameter": {
      "type": "object",
      "properties": {
        "domain": {
          "type": "string",
          "description": "Source EBI domain to search"
        },
        "query": {
          "type": "string",
          "description": "Search query. Can include cross-reference filters like 'xref_uniprot:P04637'"
        },
        "size": {
          "type": "integer",
          "default": 10,
          "description": "Number of results to return"
        },
        "format": {
          "type": "string",
          "enum": ["json", "xml"],
          "default": "json"
        }
      },
      "required": ["domain", "query"]
    },
    "fields": {
      "endpoint": "",
      "extract_path": "entries",
      "return_format": "JSON"
    },
    "return_schema": {
      "type": "array",
      "description": "Entries with cross-reference information",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entry ID"
          },
          "source": {
            "type": "string",
            "description": "Source database"
          }
        }
      }
    },
    "test_examples": [
      {
        "domain": "ensembl",
        "query": "xref_uniprot:P04637",
        "size": 10
      }
    ]
  }
]
