[
  {
    "type": "EuropePMCTool",
    "name": "EuropePMC_search_articles",
    "description": "Search for articles on Europe PMC including abstracts and metadata. Europe PMC supports fielded queries for indexed full text (e.g., BODY:\"term\") but only for records where Europe PMC has full text indexed (HAS_FT:Y). Use require_has_ft/fulltext_terms to avoid confusing 'has a full-text link somewhere' with 'full text searchable in Europe PMC'.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query for Europe PMC. Supports Lucene-like fielded syntax (e.g., BODY:\"term\", INTRO:\"term\", METHODS:\"term\")."
        },
        "limit": {
          "type": "integer",
          "description": "Number of articles to return. This sets the maximum number of articles retrieved from Europe PMC.",
          "default": 5
        },
        "require_has_ft": {
          "type": "boolean",
          "description": "If true, appends `HAS_FT:Y` to the query to restrict results to records where Europe PMC has full text indexed. This is NOT the same as having a link to free full text elsewhere (e.g., PMC) and is often the key reason body-only keywords cannot be found via Europe PMC search.",
          "default": false
        },
        "fulltext_terms": {
          "type": "array",
          "description": "Optional list of terms that must occur in the indexed full text (Europe PMC BODY field). When provided, the tool adds a BODY:\"...\" clause and automatically enables `require_has_ft`.",
          "items": {
            "type": "string"
          }
        },
        "enrich_missing_abstract": {
          "type": "boolean",
          "description": "If true, best-effort fills missing abstracts by fetching Europe PMC fullTextXML (bounded to a few results).",
          "default": false
        },
        "extract_terms_from_fulltext": {
          "type": "array",
          "description": "Optional list of terms to extract from full text (open access only). When provided, automatically fetches fullTextXML for open-access articles and returns snippets around these terms. Terms are processed in batches of 5 internally, so any number of terms is accepted. Bounded to first 3 OA articles to avoid latency. Returns snippets in a 'fulltext_snippets' field for each article.",
          "items": {
            "type": "string"
          }
        },
        "page_size": {
          "type": "integer",
          "description": "Alias for limit \u2014 number of results to return"
        }
      },
      "required": [
        "query"
      ]
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of articles from Europe PMC matching the search query",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Title of the article"
              },
              "abstract": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Abstract of the article"
              },
              "abstract_retrieval_trace": {
                "type": "array",
                "description": "Machine-readable trace of attempts used to retrieve/derive the abstract when enrichment is enabled.",
                "items": {
                  "type": "object",
                  "properties": {
                    "attempt": {
                      "type": "string"
                    },
                    "url": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "status_code": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "content_type": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "note": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              },
              "authors": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of author names"
              },
              "journal": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Journal name where the article was published"
              },
              "year": {
                "type": [
                  "integer",
                  "string",
                  "null"
                ],
                "description": "Publication year"
              },
              "doi": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Digital Object Identifier"
              },
              "doi_url": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "DOI resolver URL"
              },
              "url": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "URL to the article on Europe PMC"
              },
              "source_db": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Europe PMC source database for the record (e.g., MED, PMC)."
              },
              "article_id": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Record identifier within the Europe PMC source database (e.g., PMID for MED)."
              },
              "pmid": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "PubMed ID (when available)"
              },
              "pmcid": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "PubMed Central ID (when available)"
              },
              "fulltext_xml_url": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Europe PMC fullTextXML URL (when derivable)"
              },
              "abstract_source": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Source of abstract text (e.g., Europe PMC core or fullTextXML)"
              },
              "fulltext_snippets": {
                "type": "array",
                "description": "Full-text snippets around search terms (only present when extract_terms_from_fulltext is provided and article is OA)",
                "items": {
                  "type": "object",
                  "properties": {
                    "term": {
                      "type": "string",
                      "description": "The search term that was matched"
                    },
                    "snippet": {
                      "type": "string",
                      "description": "Text snippet with context around the matched term"
                    }
                  }
                }
              },
              "fulltext_snippets_count": {
                "type": "integer",
                "description": "Number of snippets extracted (only present when fulltext_snippets exists)"
              },
              "fulltext_snippets_source": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Provenance for snippet extraction (e.g., Europe PMC fullTextXML, NCBI PMC OAI (JATS), NCBI PMC HTML)."
              },
              "fulltext_snippets_retrieval_trace": {
                "type": "array",
                "description": "Machine-readable trace of attempts used to retrieve full text for snippet extraction.",
                "items": {
                  "type": "object",
                  "properties": {
                    "attempt": {
                      "type": "string"
                    },
                    "url": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "status_code": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "content_type": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "note": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              },
              "citations": {
                "type": "integer",
                "description": "Number of citations"
              },
              "open_access": {
                "type": "boolean",
                "description": "Open access status"
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of keywords"
              },
              "source": {
                "type": "string",
                "description": "Source identifier (always 'Europe PMC')"
              },
              "data_quality": {
                "type": "object",
                "description": "Data quality indicators",
                "properties": {
                  "has_abstract": {
                    "type": "boolean"
                  },
                  "has_authors": {
                    "type": "boolean"
                  },
                  "has_journal": {
                    "type": "boolean"
                  },
                  "has_year": {
                    "type": "boolean"
                  },
                  "has_doi": {
                    "type": "boolean"
                  },
                  "has_citations": {
                    "type": "boolean"
                  },
                  "has_keywords": {
                    "type": "boolean"
                  },
                  "has_url": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Error response",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "query": "cancer therapy",
        "limit": 5
      }
    ]
  },
  {
    "type": "EuropePMCRESTTool",
    "name": "EuropePMC_get_citations",
    "description": "Get citations for an article from Europe PMC. Citations are articles that cite the specified article. Requires a source (e.g., 'MED' for PubMed, 'PMC' for PMC) and article ID. Use EuropePMC_search_articles to find article IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source database (e.g., 'MED' for PubMed, 'PMC' for PMC). Usually 'MED' for most articles.",
          "default": "MED"
        },
        "article_id": {
          "type": "string",
          "description": "Article ID from the source database (e.g., PMID for MED source)"
        },
        "page_size": {
          "type": "integer",
          "description": "Number of citations to retrieve (default: 25, max: 1000)",
          "default": 25,
          "minimum": 1,
          "maximum": 1000
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination (default: 1)",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "article_id"
      ]
    },
    "fields": {
      "endpoint": "https://www.ebi.ac.uk/europepmc/webservices/rest/{source}/{article_id}/citations"
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success",
                "error"
              ]
            },
            "data": {
              "type": "object",
              "properties": {
                "version": {
                  "type": "string"
                },
                "hitCount": {
                  "type": "integer"
                },
                "citationList": {
                  "type": "object",
                  "properties": {
                    "citation": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "source": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "authorString": {
                            "type": "string"
                          },
                          "journalAbbreviation": {
                            "type": "string"
                          },
                          "pubYear": {
                            "type": [
                              "integer",
                              "string"
                            ]
                          },
                          "citedOrder": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "url": {
              "type": "string"
            },
            "error": {
              "type": "string"
            },
            "status_code": {
              "type": "integer"
            }
          }
        },
        {
          "type": "object",
          "description": "Error response",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "source": "MED",
        "article_id": "25428363",
        "page_size": 10
      }
    ]
  },
  {
    "type": "EuropePMCRESTTool",
    "name": "EuropePMC_get_references",
    "description": "Get references (bibliography) for an article from Europe PMC. References are articles cited by the specified article. Requires a source (e.g., 'MED' for PubMed, 'PMC' for PMC) and article ID. Use EuropePMC_search_articles to find article IDs first.",
