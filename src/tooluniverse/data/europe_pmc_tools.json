                  "type": "integer"
                },
                "referenceList": {
                  "type": "object",
                  "properties": {
                    "reference": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "source": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "authorString": {
                            "type": "string"
                          },
                          "journalAbbreviation": {
                            "type": "string"
                          },
                          "pubYear": {
                            "type": [
                              "integer",
                              "string"
                            ]
                          },
                          "citedOrder": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "url": {
              "type": "string"
            },
            "error": {
              "type": "string"
            },
            "status_code": {
              "type": "integer"
            }
          }
        },
        {
          "type": "object",
          "description": "Error response",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "source": "MED",
        "article_id": "25428363",
        "page_size": 10
      }
    ]
  },
  {
    "type": "EuropePMCFullTextFetchTool",
    "name": "EuropePMC_get_fulltext",
    "description": "Fetch a PMC article's full text with deterministic fallbacks: Europe PMC fullTextXML \u2192 NCBI PMC OAI (JATS) \u2192 NCBI efetch (XML) \u2192 PMC HTML. Designed for machine consumption: returns structured provenance (source/format/content_type) and a retrieval_trace of every attempt.",
    "parameter": {
      "type": "object",
      "properties": {
        "fulltext_xml_url": {
          "type": "string",
          "description": "Direct Europe PMC fullTextXML URL (optional)."
        },
        "pmcid": {
          "type": "string",
          "description": "PMC ID (e.g., 'PMC5234727' or '5234727')."
        },
        "source_db": {
          "type": "string",
          "description": "Europe PMC source database (e.g., 'MED' or 'PMC'). Used with `article_id` to derive a Europe PMC fullTextXML URL."
        },
        "article_id": {
          "type": "string",
          "description": "Europe PMC article ID within `source_db` (e.g., PMID for source_db='MED')."
        },
        "output_format": {
          "type": "string",
          "description": "Return 'text' (default; extracted plain text) or 'raw' (raw XML/HTML).",
          "default": "text",
          "enum": [
            "text",
            "raw"
          ]
        },
        "include_raw": {
          "type": "boolean",
          "description": "If true, also returns a bounded `raw` field (useful for downstream parsing).",
          "default": false
        },
        "max_chars": {
          "type": "integer",
          "description": "Hard cap on characters returned in `text` (or `content` when output_format='raw').",
          "default": 200000,
          "minimum": 1000,
          "maximum": 2000000
        },
        "max_raw_chars": {
          "type": "integer",
          "description": "Hard cap on characters returned in `raw` when include_raw=true.",
          "default": 200000,
          "minimum": 1000,
          "maximum": 2000000
        },
        "timeout": {
          "type": "integer",
          "description": "HTTP timeout in seconds.",
          "default": 30,
          "minimum": 5,
          "maximum": 120
        }
      }
    },
    "return_schema": {
      "oneOf": [
        {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success",
                "error"
              ]
            },
            "url": {
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "type": [
                "string",
                "null"
              ]
            },
            "format": {
              "type": [
                "string",
                "null"
              ]
            },
            "content_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "retrieval_trace": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "attempt": {
                    "type": "string"
                  },
                  "url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "status_code": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "content_type": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "note": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "text": {
              "type": "string",
              "description": "Extracted plain text (when output_format='text')."
            },
            "content": {
              "type": "string",
              "description": "Raw XML/HTML (when output_format='raw')."
            },
            "truncated": {
              "type": "boolean"
            },
            "raw": {
              "type": [
                "string",
                "null"
              ]
            },
            "raw_truncated": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "status_code": {
              "type": "integer"
            },
            "retryable": {
              "type": "boolean"
            },
            "error": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "description": "Error response",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "pmcid": "PMC5234727",
        "output_format": "text",
        "max_chars": 4000
      }
    ]
  },
  {
    "type": "EuropePMCFullTextSnippetsTool",
    "name": "EuropePMC_get_fulltext_snippets",
    "description": "Fetch an article's full text (best-effort) and return bounded text snippets around provided terms. Uses deterministic fallbacks: Europe PMC fullTextXML \u2192 NCBI PMC OAI (JATS) \u2192 NCBI efetch (XML) \u2192 PMC HTML. Returns a machine-readable retrieval_trace so callers can see exactly what succeeded/failed.",
    "parameter": {
      "type": "object",
      "properties": {
        "fulltext_xml_url": {
          "type": "string",
          "description": "Direct Europe PMC fullTextXML URL (recommended when you already have it from EuropePMC_search_articles)."
        },
        "pmcid": {
          "type": "string",
          "description": "PMC ID (e.g., 'PMC11237425' or '11237425'). If provided, the tool derives the Europe PMC fullTextXML URL."
        },
        "source_db": {
          "type": "string",
          "description": "Europe PMC source database (e.g., 'MED' or 'PMC'). Used with `article_id` to derive the fullTextXML URL."
        },
        "article_id": {
          "type": "string",
          "description": "Europe PMC article ID within `source_db` (e.g., PMID for source_db='MED')."
        },
        "terms": {
          "type": "array",
          "description": "Terms to search for in the extracted full text (case-insensitive).",
          "items": {
            "type": "string"
          }
        },
        "keywords": {
          "type": "array",
          "description": "Alias for `terms` (case-insensitive). Provided for backwards/UX compatibility.",
          "items": {
            "type": "string"
          }
        },
        "window_chars": {
          "type": "integer",
          "description": "Context window size (characters) before and after each match.",
          "default": 220,
          "minimum": 20,
          "maximum": 2000
        },
        "max_snippets_per_term": {
          "type": "integer",
          "description": "Maximum number of snippets returned per term.",
          "default": 3,
          "minimum": 1,
          "maximum": 10
        },
        "max_total_chars": {
          "type": "integer",
          "description": "Hard cap on total characters returned across all snippets.",
          "default": 8000,
          "minimum": 1000,
          "maximum": 50000
        }
      },
      "anyOf": [
        {
          "required": [
            "terms"
          ]
        },
        {
          "required": [
            "keywords"
          ]
        }
      ]
    },
    "return_schema": {
      "oneOf": [
        {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success",
                "error"
              ]
            },
            "url": {
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "type": [
                "string",
                "null"
              ],
              "description": "Provenance of the retrieved full text used for snippet extraction."
            },
            "format": {
              "type": [
                "string",
                "null"
              ],
              "description": "Underlying format of the retrieved full text (xml or html)."
            },
            "content_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "HTTP Content-Type of the retrieved response (when available)."
            },
            "retrieval_trace": {
              "type": "array",
              "description": "Machine-readable trace of attempts used to retrieve full text.",
              "items": {
                "type": "object",
                "properties": {
                  "attempt": {
                    "type": "string"
                  },
                  "url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "status_code": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "content_type": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "note": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "snippets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "term": {
                    "type": "string"
                  },
                  "snippet": {
                    "type": "string"
                  }
                }
              }
            },
            "snippets_count": {
              "type": "integer"
            },
            "truncated": {
              "type": "boolean"
            },
            "error": {
              "type": "string"
            },
            "status_code": {
              "type": "integer"
            },
            "retryable": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "description": "Error response",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "pmcid": "PMC11237425",
        "terms": [
          "ciprofloxacin",
          "evolved resistance"
        ]
      }
