      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source database (e.g., 'MED' for PubMed, 'PMC' for PMC). Usually 'MED' for most articles.",
          "default": "MED"
        },
        "article_id": {
          "type": "string",
          "description": "Article ID from the source database (e.g., PMID for MED source)"
        },
        "page_size": {
          "type": "integer",
          "description": "Number of references to retrieve (default: 25, max: 1000)",
          "default": 25,
          "minimum": 1,
          "maximum": 1000
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination (default: 1)",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "article_id"
      ]
    },
    "fields": {
      "endpoint": "https://www.ebi.ac.uk/europepmc/webservices/rest/{source}/{article_id}/references"
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success",
                "error"
              ]
            },
