  {
    "name": "GenCC_get_classifications",
    "description": "Get summary statistics of gene-disease validity classifications from GenCC. Returns counts per classification level (Definitive, Strong, Moderate, Limited, etc.). Optionally filter by gene_symbol (e.g., 'GBA'), disease name substring, or submitter organization. Without filters, returns global stats across all 40,000+ curated submissions.",
    "type": "GenCCTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_classifications",
          "description": "Operation type (fixed: get_classifications)"
        },
        "gene_symbol": {
          "type": "string",
          "description": "Optional HGNC gene symbol to filter classification stats (e.g., 'GBA', 'BRCA2')"
        },
        "disease": {
          "type": "string",
          "description": "Optional disease name substring to filter classification stats (e.g., 'Gaucher', 'breast cancer')"
        },
        "submitter": {
          "type": "string",
          "description": "Optional filter by submitting organization name (e.g., 'ClinGen', 'Ambry', 'Genomics England')",
          "default": ""
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "classifications": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "classification": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  },
                  "rank": {
                    "type": "integer"
                  }
                }
              }
            },
            "total_submissions": {
              "type": "integer"
            },
            "unique_genes": {
              "type": "integer"
            },
            "unique_diseases": {
              "type": "integer"
            },
            "top_submitters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "test_examples": [
      {},
      {
        "submitter": "ClinGen"
      }
    ]
  }
