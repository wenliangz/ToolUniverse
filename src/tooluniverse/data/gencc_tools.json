                  "mode_of_inheritance": {
                    "type": "string"
                  },
                  "submitter": {
                    "type": "string"
                  },
                  "submitted_date": {
                    "type": "string"
                  }
                }
              }
            },
            "submission_count": {
              "type": "integer"
            },
            "unique_genes": {
              "type": "integer"
            }
          }
