    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_disease",
          "description": "Operation type (fixed: search_disease)"
        },
        "disease": {
          "type": "string",
          "description": "Disease name or ID to search (e.g., 'Marfan syndrome', 'MONDO:0007947', 'breast cancer')"
        },
        "disease_name": {
          "type": "string",
          "description": "Alias for disease. Disease name or ID to search."
        },
        "classification": {
          "type": "string",
          "description": "Optional filter by classification level (e.g., Definitive, Strong)",
          "default": ""
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "disease": {
              "type": "string"
            },
            "submissions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "gene_symbol": {
                    "type": "string"
                  },
                  "gene_curie": {
                    "type": "string"
                  },
                  "disease_title": {
                    "type": "string"
