      "return_format": "JSON",
      "query_schema": "query($variantId: String!, $dataset: DatasetId!) { variant(variantId: $variantId, dataset: $dataset) { variant_id chrom pos ref alt rsid genome { af an ac } exome { af an ac } } }",
      "variable_map": { "variant_id": "variantId" },
