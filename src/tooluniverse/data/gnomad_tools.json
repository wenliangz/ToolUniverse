                  }
                },
                "exome": {
                  "type": ["object", "null"],
                  "properties": {
                    "af": { "type": ["number", "null"] },
                    "an": { "type": ["integer", "null"] },
                    "ac": { "type": ["integer", "null"] }
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
