[
  {
    "name": "GtoPdb_search_targets",
    "description": "Search the Guide to Pharmacology database (GtoPdb) for drug targets including GPCRs, ion channels, nuclear receptors, enzymes, transporters, and catalytic receptors. Returns target IDs, names, abbreviations, types, and family classifications. GtoPdb is the IUPHAR/BPS reference resource for pharmacological drug targets with 3000+ curated targets. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Target name or gene symbol to search. Examples: 'dopamine', 'serotonin receptor', 'EGFR', 'beta-adrenoceptor', 'TRPV1'"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Target type filter. Values: 'GPCR', 'Ion channel', 'Nuclear receptor', 'Enzyme', 'Transporter', 'Catalytic receptor'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.guidetopharmacology.org/services/targets",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "dopamine"},
      {"name": "serotonin", "type": "GPCR"},
      {"name": "EGFR"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of pharmacological targets",
          "items": {
            "type": "object",
            "properties": {
              "targetId": {"type": "integer", "description": "GtoPdb target ID"},
              "name": {"type": "string", "description": "Full target name"},
              "abbreviation": {"type": ["string", "null"], "description": "Common abbreviation"},
              "type": {"type": "string", "description": "Target type (GPCR, Ion channel, etc.)"},
              "familyIds": {"type": "array", "items": {"type": "integer"}, "description": "Family IDs"},
              "subunitIds": {"type": "array", "items": {"type": "integer"}},
              "complexIds": {"type": "array", "items": {"type": "integer"}}
            }
          }
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "GtoPdb_search_ligands",
    "description": "Search the Guide to Pharmacology database for pharmacological ligands (drugs, natural products, endogenous compounds). Returns ligand details including type, approval status, INN name, WHO essential medicine status, and whether it is an approved drug. GtoPdb covers 10,000+ curated ligands with pharmacological activity data. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Ligand name or INN to search. Examples: 'aspirin', 'morphine', 'dopamine', 'caffeine', 'insulin'"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Ligand type filter. Values: 'Approved', 'Synthetic organic', 'Natural product', 'Endogenous peptide', 'Antibody', 'Inorganic'"
        },
        "approved": {
          "type": ["boolean", "null"],
          "description": "Filter to approved drugs only (true) or all ligands (false/omit)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.guidetopharmacology.org/services/ligands",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "aspirin"},
      {"name": "morphine", "approved": true},
      {"name": "dopamine", "type": "Endogenous peptide"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of pharmacological ligands",
          "items": {
            "type": "object",
            "properties": {
              "ligandId": {"type": "integer", "description": "GtoPdb ligand ID"},
              "name": {"type": "string", "description": "Ligand name"},
              "type": {"type": "string", "description": "Ligand type"},
              "abbreviation": {"type": ["string", "null"]},
              "inn": {"type": ["string", "null"], "description": "International Non-proprietary Name"},
              "approvalSource": {"type": ["string", "null"], "description": "FDA/EMA approval source"},
              "approved": {"type": "boolean", "description": "Is an approved drug"},
              "whoEssential": {"type": "boolean", "description": "On WHO Essential Medicines List"}
            }
          }
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "GtoPdb_get_interactions",
    "description": "Get pharmacological interactions between targets and ligands from the Guide to Pharmacology database. Provide targetId (from GtoPdb_search_targets) or ligandId (from GtoPdb_search_ligands) to filter interactions. Returns binding affinity (Ki, Kd, IC50, EC50), action type (agonist, antagonist, inhibitor, etc.), species, and assay information. Essential for drug discovery and pharmacology research. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "targetId": {
          "type": ["integer", "null"],
          "description": "GtoPdb target ID. Get from GtoPdb_search_targets. Examples: 2486 (dopamine beta-hydroxylase), 20 (5-HT1A receptor)"
        },
        "ligandId": {
          "type": ["integer", "null"],
          "description": "GtoPdb ligand ID. Get from GtoPdb_search_ligands. Examples: 5765 (aspirin), 7093 (morphine)"
        },
        "species": {
          "type": ["string", "null"],
          "description": "Filter by species. Examples: 'Human', 'Mouse', 'Rat'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.guidetopharmacology.org/services/interactions",
      "params": {}
    },
    "type": "GtoPdbRESTTool",
    "test_examples": [
      {"targetId": 20},
      {"targetId": 2486, "species": "Human"},
      {"ligandId": 7093}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of target-ligand interactions",
          "items": {
            "type": "object",
            "properties": {
              "targetId": {"type": "integer"},
              "targetName": {"type": "string", "description": "Target name"},
              "ligandId": {"type": ["integer", "null"]},
              "ligandName": {"type": "string", "description": "Ligand name"},
              "type": {"type": "string", "description": "Interaction type (Agonist, Antagonist, Inhibitor, etc.)"},
              "targetSpecies": {"type": "string", "description": "Species (Human, Mouse, Rat)"},
              "primaryTarget": {"type": "boolean", "description": "Is primary target"},
              "endogenous": {"type": "boolean", "description": "Is endogenous ligand"},
              "affinityUnits": {"type": ["string", "null"], "description": "Affinity units (pKi, pIC50, etc.)"},
              "affinityMedian": {"type": ["number", "null"], "description": "Median affinity value"}
            }
          }
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
