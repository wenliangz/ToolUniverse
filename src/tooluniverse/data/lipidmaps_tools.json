[
  {
    "name": "LipidMaps_get_compound_by_id",
    "description": "Get lipid structure and classification by LIPID MAPS ID (LMID). Returns full lipid record including name, formula, exact mass, SMILES, InChI, cross-references to KEGG/HMDB/ChEBI/PubChem. Example: 'LMFA08040013' returns Palmitoyl-EA.",
    "parameter": {
      "type": "object",
      "properties": {
        "input_value": {
          "type": "string",
          "description": "LIPID MAPS ID (LMID), e.g., 'LMFA08040013'. Format: LM + 2-letter category + 8-digit number."
        },
        "output_item": {
          "type": "string",
          "description": "Type of output. Options: 'all' (complete record), 'name', 'formula', 'exactmass', 'smiles', 'classification', 'molfile'.",
          "default": "all"
        }
      },
      "required": [
        "input_value"
      ]
    },
    "fields": {
      "context": "compound",
      "input_item": "lm_id"
    },
    "type": "LipidMapsTool",
    "test_examples": [
      {
        "input_value": "LMFA08040013"
      },
      {
        "input_value": "LMFA01030185",
        "output_item": "all"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "lm_id": {
          "type": ["string", "null"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "sys_name": {
          "type": ["string", "null"]
        },
        "formula": {
          "type": ["string", "null"]
        },
        "exactmass": {
          "type": ["string", "null"]
        },
        "smiles": {
          "type": ["string", "null"]
        },
        "inchi_key": {
          "type": ["string", "null"]
        },
        "core": {
          "type": ["string", "null"]
        },
        "main_class": {
          "type": ["string", "null"]
        },
        "sub_class": {
          "type": ["string", "null"]
        },
        "kegg_id": {
          "type": ["string", "null"]
        },
        "hmdb_id": {
          "type": ["string", "null"]
        },
        "chebi_id": {
          "type": ["string", "null"]
        },
        "pubchem_cid": {
          "type": ["string", "null"]
        },
        "input": {
          "type": ["string", "null"]
        },
        "regno": {
          "type": ["string", "null"]
        },
        "abbrev": {
          "type": ["string", "null"]
        }
