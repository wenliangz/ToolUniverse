        "data": {
          "type": "object",
          "properties": {
            "hugoSymbol": {
              "type": "string",
              "description": "Official gene symbol"
            },
            "oncogene": {
              "type": "boolean",
              "description": "Whether gene is classified as oncogene"
            },
            "tsg": {
              "type": "boolean",
              "description": "Whether gene is a tumor suppressor gene"
            },
            "geneAliases": {
              "type": "array",
              "description": "Alternative gene names"
            }
          }
        }
      }
    },
    "test_examples": [
