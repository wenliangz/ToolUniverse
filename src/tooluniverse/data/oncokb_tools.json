  {
    "name": "OncoKB_annotate_copy_number",
    "description": "Annotate copy number alterations (amplification/deletion) for oncogenic potential. Returns evidence for gene amplification or deletion in cancer. Example: ERBB2 amplification in breast cancer, CDKN2A deletion.",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "annotate_copy_number",
          "description": "Operation type (fixed: annotate_copy_number)"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., ERBB2, MYC, CDKN2A)"
        },
        "copy_number_type": {
          "type": "string",
          "enum": [
            "AMPLIFICATION",
            "DELETION",
            "Amplification",
            "Deletion",
            "amplification",
            "deletion"
          ],
          "description": "Type of copy number alteration (case-insensitive: AMPLIFICATION or DELETION)"
        },
        "tumor_type": {
          "type": "string",
          "description": "Optional OncoTree tumor type code"
        },
        "copy_number_alteration": {
          "type": "string",
          "description": "Alias for copy_number_type. Amplification or Deletion."
        }
      },
      "required": [
        "gene"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "oncogenic": {
              "type": "string"
            },
            "highestSensitiveLevel": {
              "type": "string"
            },
            "treatments": {
              "type": "array"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "gene": "ERBB2",
        "copy_number_type": "AMPLIFICATION"
      }
    ],
    "optional_api_keys": [
      "ONCOKB_API_TOKEN"
    ]
  }
]
