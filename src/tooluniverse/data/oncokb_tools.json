[
  {
    "name": "OncoKB_annotate_mutations",
    "description": "Annotate a cancer mutation using OncoKB. Accepts query string like 'BRAF V600E' or separate gene/variant parameters. Returns oncogenicity, mutation effect, and FDA-approved therapies. Alias for OncoKB_annotate_variant with query-string parsing. Demo mode available for BRAF, TP53, ROS1.",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "annotate_variant",
          "description": "Operation type (fixed: annotate_variant)"
        },
        "query": {
          "type": "string",
          "description": "Mutation query string, e.g. 'BRAF V600E' or 'EGFR T790M'. Gene and variant separated by space."
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., BRAF, EGFR, TP53)"
        },
        "variant": {
          "type": "string",
          "description": "Protein change (e.g., V600E, T790M)"
        },
        "tumor_type": {
          "type": "string",
          "description": "Optional OncoTree tumor type code (e.g., MEL, LUAD)"
        }
      },
      "required": []
    },
    "fields": {
      "operation": "annotate_variant"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["success", "error"]},
        "data": {"type": "object"},
        "error": {"type": "string"}
      }
    },
    "test_examples": [
      {"query": "BRAF V600E"},
      {"gene": "BRAF", "variant": "V600E"}
    ]
  },
  {
    "name": "OncoKB_annotate_variant",
    "description": "Annotate a cancer variant for oncogenic potential and treatment implications using OncoKB. Returns evidence level, oncogenicity, mutation effect, and FDA-approved therapies. Requires ONCOKB_API_TOKEN env var (demo mode available for BRAF, TP53, ROS1). Example: BRAF V600E in melanoma.",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "annotate_variant",
          "description": "Operation type (fixed: annotate_variant)"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., BRAF, EGFR, TP53, KRAS)"
        },
        "gene_symbol": {
          "type": "string",
          "description": "Alias for gene. Gene symbol (e.g., BRAF, EGFR, TP53, KRAS)."
        },
        "variant": {
          "type": "string",
          "description": "Variant notation - protein change (e.g., V600E, T790M, G12D)"
        },
        "tumor_type": {
          "type": "string",
          "description": "Optional OncoTree tumor type code (e.g., MEL for melanoma, LUAD for lung adenocarcinoma)"
        },
        "alteration": {
          "type": "string",
          "description": "Alias for variant. Protein change notation (e.g., \"V600E\", \"T790M\", \"G12D\")."
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "data": {
          "type": "object",
          "properties": {
            "oncogenic": {
              "type": "string",
              "description": "Oncogenicity classification (Oncogenic, Likely Oncogenic, etc.)"
            },
            "mutationEffect": {
              "type": "object",
              "description": "Mutation effect on protein function"
            },
            "highestSensitiveLevel": {
              "type": "string",
              "description": "Highest level of evidence for drug sensitivity"
            },
            "treatments": {
              "type": "array",
              "description": "List of treatment options with evidence levels"
            }
          }
        },
        "error": {
          "type": "string"
        }
      }
    },
    "test_examples": [
      {
        "gene": "BRAF",
        "variant": "V600E"
      },
      {
        "gene": "BRAF",
        "variant": "V600E",
        "tumor_type": "MEL"
      }
    ],
    "optional_api_keys": [
      "ONCOKB_API_TOKEN"
    ]
  },
  {
    "name": "OncoKB_get_gene_info",
    "description": "Get gene-level oncogenic information from OncoKB. Returns whether gene is an oncogene, tumor suppressor, or both. Includes curated background information. Requires ONCOKB_API_TOKEN env var (demo mode available for BRAF, TP53, ROS1).",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_gene_info",
          "description": "Operation type (fixed: get_gene_info)"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., BRAF, TP53, ROS1). Without ONCOKB_API_TOKEN only BRAF, TP53, and ROS1 are available (demo mode)."
        },
        "gene_symbol": {
          "type": "string",
          "description": "Gene symbol alias \u2014 alternative to gene parameter"
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
