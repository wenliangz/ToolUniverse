[
  {
    "type": "STRINGRESTTool",
    "name": "STRING_get_protein_interactions",
    "description": "Query protein-protein interactions from the STRING database. STRING is a comprehensive database of known and predicted protein-protein interactions with confidence scores and functional annotations.",
    "parameter": {
      "type": "object",
      "properties": {
        "protein_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of protein identifiers (UniProt IDs, gene names, etc.)",
          "minItems": 1
        },
        "species": {
          "type": "integer",
          "description": "NCBI taxonomy ID (default: 9606 for human)",
          "default": 9606
        },
        "confidence_score": {
          "type": "number",
          "description": "Minimum confidence score (0-1, default: 0.4)",
          "minimum": 0,
          "maximum": 1,
          "default": 0.4
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of interactions to return (default: 50)",
          "minimum": 1,
          "maximum": 1000,
          "default": 50
        },
        "network_type": {
          "type": "string",
          "description": "Type of network ('full', 'physical', 'functional')",
          "enum": [
            "full",
            "physical",
            "functional"
          ],
          "default": "full"
        }
      },
      "required": [
        "protein_ids"
      ]
    },
    "fields": {
      "endpoint": "/tsv/network",
      "return_format": "TSV"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "Array of interaction records parsed from TSV"
        },
        "header": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Column headers from the TSV response"
        },
        "error": {
          "type": "string",
          "description": "Error message if request failed"
        }
      }
    },
    "implementation": {
      "language": "python",
      "dependencies": [
        "requests"
      ],
      "source_file": "STRING_get_protein_interactions.py"
    },
    "test_examples": [
      {
        "protein_ids": ["TP53", "MDM2"],
        "species": 9606,
        "confidence_score": 0.4,
        "limit": 50,
        "network_type": "full"
      }
    ]
  },
  {
    "type": "BioGRIDRESTTool",
    "name": "BioGRID_get_interactions",
    "description": "Query protein and genetic interactions from the BioGRID database. BioGRID is a comprehensive database of physical and genetic interactions with detailed experimental evidence. Requires free BioGRID API key (register at https://webservice.thebiogrid.org/). Set BIOGRID_API_KEY environment variable in .env file.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of gene names or protein identifiers",
          "minItems": 1
        },
        "organism": {
          "type": "string",
          "description": "Organism name (e.g., 'Homo sapiens', 'Mus musculus') or NCBI taxonomy ID (e.g., '9606' for human)",
          "default": "Homo sapiens"
        },
        "interaction_type": {
          "type": "string",
          "description": "Type of interaction ('physical', 'genetic', 'both')",
          "enum": [
            "physical",
            "genetic",
            "both"
          ],
          "default": "both"
        },
        "evidence_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of evidence types to include"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of interactions to return (default: 100)",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        },
        "format": {
          "type": "string",
          "description": "Output format ('json' or 'tab', default: 'json')",
          "enum": [
            "json",
            "tab"
          ],
          "default": "json"
        }
      },
      "required": [
        "gene_names"
      ]
    },
    "required_api_keys": [
      "BIOGRID_API_KEY"
    ],
    "return_schema": {
      "type": ["object", "array"],
      "description": "BioGRID API response - can be an object with interaction data or an array of interactions"
    },
    "fields": {
      "endpoint": "/interactions/",
      "return_format": "JSON"
    },
    "test_examples": [
      {
        "gene_names": ["TP53"],
        "organism": "9606",
        "interaction_type": "physical",
        "evidence_types": [],
        "limit": 1,
        "format": "json"
      }
    ]
  }
]
