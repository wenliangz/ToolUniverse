    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": [
            "list_datasets"
          ],
          "description": "Operation type"
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "idSource": {
            "type": "integer",
            "description": "Dataset ID"
          },
          "name": {
            "type": "string",
            "description": "Dataset name"
          },
          "no_drugs": {
            "type": "integer",
