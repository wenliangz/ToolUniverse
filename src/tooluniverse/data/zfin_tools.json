  {
    "name": "ZFIN_get_allele",
    "description": "Get detailed information about a specific zebrafish allele from ZFIN via the Alliance of Genome Resources. Returns allele symbol, associated gene, alteration type, species, and synonyms. Useful for looking up specific zebrafish mutant lines. Example: 'ZFIN:ZDB-ALT-210706-1' returns the szu2 allele of pax2a with its deletion variant details.",
    "parameter": {
      "type": "object",
      "properties": {
        "allele_id": {
          "type": "string",
          "description": "ZFIN allele ID with 'ZFIN:' prefix. Examples: 'ZFIN:ZDB-ALT-210706-1' (szu2 allele of pax2a), 'ZFIN:ZDB-ALT-980203-1590' (tm243a allele of pax2a)."
        }
      },
      "required": [
